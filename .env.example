# Local discovery script
MUSE_API_URL=http://YOUR_AWS_IP/api/muse

# Source credentials (for local discovery)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=muse:v1.0.0
PRODUCTHUNT_API_TOKEN=

